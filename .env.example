# OpenRouter API key — get yours free at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production

# Token expiry in hours (default: 24)
JWT_EXPIRE_HOURS=24

# SQLite database URL
# Local:  sqlite:///./study_assistant.db
# Render: sqlite:////data/study_assistant.db
DATABASE_URL=sqlite:///./study_assistant.db
